if (!function_exists('bkic_api_register_device')) {
    function bkic_api_register_device(WP_REST_Request $request) {
        global $wpdb;

        $user = bkic_get_authenticated_user($request);

        if (!$user) {
            return new WP_REST_Response([
                'success' => false,
                'message' => 'Ikke autoriseret',
            ], 401);
        }

        $json = $request->get_json_params();
        if (!is_array($json)) {
            $json = [];
        }

        $platform = sanitize_text_field((string) ($request->get_param('platform') ?: ($json['platform'] ?? '')));
        $device_token = trim((string) ($request->get_param('device_token') ?: ($json['device_token'] ?? '')));
        $app_version = sanitize_text_field((string) ($request->get_param('app_version') ?: ($json['app_version'] ?? '')));
        $locale = sanitize_text_field((string) ($request->get_param('locale') ?: ($json['locale'] ?? '')));

        if (!in_array($platform, ['ios', 'android', 'macos'], true) || $device_token === '') {
            bkic_push_log('Device register failed: invalid platform/token', [
                'platform' => $platform,
                'token_empty' => ($device_token === ''),
            ]);

            return new WP_REST_Response([
                'success' => false,
                'message' => 'Ugyldig platform eller token',
            ], 400);
        }

        $table = $wpdb->prefix . 'bkicsaff_mobile_devices';
        $now = current_time('mysql');

        $existing = $wpdb->get_var($wpdb->prepare(
            "SELECT id FROM {$table} WHERE device_token = %s LIMIT 1",
            $device_token
        ));

        if ($existing) {
            $wpdb->update(
                $table,
                [
                    'user_id'      => $user->ID,
                    'platform'     => $platform,
                    'app_version'  => $app_version,
                    'locale'       => $locale,
                    'is_active'    => 1,
                    'last_seen_at' => $now,
                    'updated_at'   => $now,
                ],
                ['id' => (int) $existing],
                ['%d', '%s', '%s', '%s', '%d', '%s', '%s'],
                ['%d']
            );
        } else {
            $wpdb->insert(
                $table,
                [
                    'user_id'      => $user->ID,
                    'platform'     => $platform,
                    'device_token' => $device_token,
                    'app_version'  => $app_version,
                    'locale'       => $locale,
                    'is_active'    => 1,
                    'last_seen_at' => $now,
                    'created_at'   => $now,
                    'updated_at'   => $now,
                ],
                ['%d', '%s', '%s', '%s', '%s', '%d', '%s', '%s', '%s']
            );
        }

        bkic_push_log('Device registered', [
            'user_id' => $user->ID,
            'platform' => $platform,
            'token_prefix' => substr($device_token, 0, 20) . '...',
        ]);

        return new WP_REST_Response([
            'success' => true,
            'message' => 'Enhed registreret',
        ], 200);
    }
}

