if (!function_exists('bkic_api_login')) {
    function bkic_api_login(WP_REST_Request $request) {
        $json = $request->get_json_params();
        if (!is_array($json)) {
            $json = [];
        }

        $login = trim((string) ($request->get_param('login') ?: ($json['login'] ?? '')));
        $email = sanitize_email((string) ($request->get_param('email') ?: ($json['email'] ?? '')));
        $password = (string) ($request->get_param('password') ?: ($json['password'] ?? ''));

        $identifier = $login ?: $email;

        if (!$identifier || !$password) {
            return new WP_REST_Response([
                'success' => false,
                'message' => 'Login og adgangskode er påkrævet',
            ], 400);
        }

        $user = bkic_find_user_by_identifier($identifier);

        if (!$user || !wp_check_password($password, $user->user_pass, $user->ID)) {
            return new WP_REST_Response([
                'success' => false,
                'message' => 'Ugyldigt login',
            ], 401);
        }

        $token = wp_generate_password(64, false, false);

        update_user_meta($user->ID, 'bkic_app_token', $token);
        update_user_meta($user->ID, 'bkic_app_token_created_at', current_time('mysql'));

        bkic_push_log('User login success', [
            'user_id' => $user->ID,
            'email' => $user->user_email,
        ]);

        return new WP_REST_Response([
            'success' => true,
            'data' => [
                'token' => $token,
                'user'  => [
                    'id'    => $user->ID,
                    'name'  => $user->display_name,
                    'email' => $user->user_email,
                    'login' => $user->user_login,
                ]
            ]
        ], 200);
    }
}

