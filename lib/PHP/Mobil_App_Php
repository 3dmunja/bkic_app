        }

        $table = $wpdb->prefix . 'bkicsaff_mobile_devices';

        $wpdb->update(
            $table,
            [
                'is_active'  => 0,
                'updated_at' => current_time('mysql'),
            ],
            [
                'device_token' => $device_token,
            ],
            ['%d', '%s'],
            ['%s']
        );
    }
}

if (!function_exists('bkic_push_send_to_token')) {
    function bkic_push_send_to_token($device_token, array $payload) {
        if (!bkic_push_enabled()) {
            return new WP_Error('fcm_disabled', 'FCM er ikke aktiveret');
        }

        $access_token = bkic_push_get_access_token();
        if (is_wp_error($access_token)) {
            return $access_token;
        }

        $device_token = trim((string) $device_token);
        if ($device_token === '') {
            return new WP_Error('empty_token', 'Tom device token');
        }

        $message = [
            'message' => [
                'token' => $device_token,
                'notification' => [
                    'title' => (string) ($payload['title'] ?? 'BKIC SAFF'),
                    'body'  => (string) ($payload['body'] ?? ''),
                ],
                'data' => array_map('strval', (array) ($payload['data'] ?? [])),
                'android' => [
                    'priority' => 'high',
                    'notification' => [
                        'channel_id' => 'bkic_default',
                        'sound'      => 'default',
                    ],
                ],
                'apns' => [
                    'headers' => [
                        'apns-priority' => '10',
                    ],
                    'payload' => [
                        'aps' => [
                            'sound' => 'default',
                        ],
                    ],
                ],
            ],
        ];

        $url = 'https://fcm.googleapis.com/v1/projects/' . rawurlencode(BKIC_FCM_PROJECT_ID) . '/messages:send';

        $response = wp_remote_post($url, [
            'timeout' => 20,
            'headers' => [
                'Authorization' => 'Bearer ' . $access_token,
                'Content-Type'  => 'application/json; charset=utf-8',
            ],
            'body' => wp_json_encode($message),
        ]);

        if (is_wp_error($response)) {
            return $response;
        }

        $code = (int) wp_remote_retrieve_response_code($response);
        $body = wp_remote_retrieve_body($response);
        $data = json_decode($body, true);

        if ($code >= 200 && $code < 300) {
            return [
                'success' => true,
                'response' => $data,
            ];
        }

        $error_message = 'FCM send fejl';

        if (is_array($data) && !empty($data['error']['message'])) {
            $error_message = (string) $data['error']['message'];
        }

        if (
            stripos($error_message, 'UNREGISTERED') !== false
            || stripos($error_message, 'registration token is not a valid') !== false
            || stripos($error_message, 'Requested entity was not found') !== false
        ) {
            bkic_push_deactivate_device_token($device_token);
        }

        return new WP_Error('fcm_send_failed', $error_message, [
            'status_code' => $code,
            'response'    => $data,
            'raw'         => $body,
        ]);
    }
}

if (!function_exists('bkic_push_send_to_all_devices')) {
    function bkic_push_send_to_all_devices(array $payload) {
        $tokens = bkic_push_get_active_device_tokens();

        if (empty($tokens)) {
            bkic_push_log('No active device tokens found');
            return [
                'sent'   => 0,
                'failed' => 0,
                'errors' => [],
            ];
        }

        $sent = 0;
        $failed = 0;
        $errors = [];

        foreach ($tokens as $token) {
            $result = bkic_push_send_to_token($token, $payload);
            if (is_wp_error($result)) {
                $failed++;
                $errors[] = [
                    'token' => substr($token, 0, 20) . '...',
                    'error' => $result->get_error_message(),
                    'data'  => $result->get_error_data(),
                ];
            } else {
                $sent++;
            }
        }

        return [
            'sent'   => $sent,
            'failed' => $failed,
            'errors' => $errors,
        ];
    }
}

if (!function_exists('bkic_push_event_fingerprint')) {
    function bkic_push_event_fingerprint($event) {
        $id = (string) ($event['id'] ?? '');
        if ($id !== '') {
            return 'event_' . sanitize_key($id);
        }

        $base = wp_json_encode([
            'title' => (string) ($event['title'] ?? ''),
            'date'  => (string) ($event['date'] ?? ''),
            'time'  => (string) ($event['time'] ?? ''),
        ]);

        return 'event_' . md5($base);
    }
}

