if (!function_exists('bkic_push_enabled')) {
    function bkic_push_enabled() {
        $enabled = BKIC_FCM_ENABLED
            && BKIC_FCM_PROJECT_ID
            && BKIC_FCM_SERVICE_ACCOUNT_JSON
            && file_exists(BKIC_FCM_SERVICE_ACCOUNT_JSON);

        if (!$enabled) {
            bkic_push_log('FCM disabled or missing config', [
                'enabled_flag' => BKIC_FCM_ENABLED,
                'project_id'   => BKIC_FCM_PROJECT_ID,
                'json_path'    => BKIC_FCM_SERVICE_ACCOUNT_JSON,
                'file_exists'  => file_exists(BKIC_FCM_SERVICE_ACCOUNT_JSON),
            ]);
        }

        return $enabled;
    }
}

if (!function_exists('bkic_push_base64url_encode')) {
    function bkic_push_base64url_encode($data) {
        return rtrim(strtr(base64_encode($data), '+/', '-_'), '=');
    }
}

if (!function_exists('bkic_push_get_service_account')) {
    function bkic_push_get_service_account() {
        static $cached = null;

        if ($cached !== null) {
            return $cached;
        }

        if (!bkic_push_enabled()) {
            return null;
        }

        $json = @file_get_contents(BKIC_FCM_SERVICE_ACCOUNT_JSON);
        if (!$json) {
            bkic_push_log('Could not read service account JSON');
            return null;
        }

        $data = json_decode($json, true);
        if (!is_array($data)) {
            bkic_push_log('Invalid service account JSON');
            return null;
        }

        if (empty($data['client_email']) || empty($data['private_key']) || empty($data['token_uri']) || empty($data['project_id'])) {
            bkic_push_log('Missing fields in service account JSON');
            return null;
        }

        $cached = $data;
        return $cached;
    }
}

if (!function_exists('bkic_push_get_access_token')) {
    function bkic_push_get_access_token() {
        $cached = get_transient('bkic_fcm_access_token');
        if (
            is_array($cached)
            && !empty($cached['token'])
            && !empty($cached['expires'])
            && (int) $cached['expires'] > time() + 60
        ) {
            return $cached['token'];
        }

        $sa = bkic_push_get_service_account();
        if (!$sa) {
            return new WP_Error('fcm_config', 'FCM service account ikke konfigureret');
        }

        $now = time();

        $header = [
            'alg' => 'RS256',
            'typ' => 'JWT',
        ];

        $claim = [
            'iss'   => $sa['client_email'],
            'scope' => 'https://www.googleapis.com/auth/firebase.messaging',
            'aud'   => $sa['token_uri'],
            'iat'   => $now,
            'exp'   => $now + 3600,
        ];

        $jwt_header = bkic_push_base64url_encode(wp_json_encode($header));
        $jwt_claim  = bkic_push_base64url_encode(wp_json_encode($claim));
        $unsigned   = $jwt_header . '.' . $jwt_claim;

        $signature = '';
        $ok = openssl_sign($unsigned, $signature, $sa['private_key'], 'sha256WithRSAEncryption');

        if (!$ok) {
            return new WP_Error('fcm_sign', 'Kunne ikke signere JWT');
        }

        $jwt = $unsigned . '.' . bkic_push_base64url_encode($signature);

        $response = wp_remote_post($sa['token_uri'], [
            'timeout' => 20,
            'headers' => [
                'Content-Type' => 'application/x-www-form-urlencoded',
            ],
            'body' => [
                'grant_type' => 'urn:ietf:params:oauth:grant-type:jwt-bearer',
                'assertion'  => $jwt,
            ],
        ]);

        if (is_wp_error($response)) {
            return $response;
        }

        $code = (int) wp_remote_retrieve_response_code($response);
        $body = wp_remote_retrieve_body($response);
        $data = json_decode($body, true);

        if ($code < 200 || $code >= 300 || empty($data['access_token'])) {
            return new WP_Error('fcm_token', 'Kunne ikke hente FCM access token', [
                'status_code' => $code,
                'response'    => $data,
                'raw'         => $body,
            ]);
        }

        $expires_in = !empty($data['expires_in']) ? (int) $data['expires_in'] : 3600;

        set_transient('bkic_fcm_access_token', [
            'token'   => $data['access_token'],
            'expires' => time() + max(300, $expires_in - 120),
        ], max(300, $expires_in - 120));

        return $data['access_token'];
    }
}

if (!function_exists('bkic_push_get_active_device_tokens')) {
    function bkic_push_get_active_device_tokens() {
        global $wpdb;

        $table = $wpdb->prefix . 'bkicsaff_mobile_devices';

        $rows = $wpdb->get_col(
            "SELECT device_token
             FROM {$table}
             WHERE is_active = 1
               AND device_token <> ''"
        );

        if (!is_array($rows)) {
            return [];
        }

        $rows = array_map('strval', $rows);
        $rows = array_filter($rows, function ($token) {
            return trim($token) !== '';
        });

        return array_values(array_unique($rows));
    }
}

if (!function_exists('bkic_push_deactivate_device_token')) {
