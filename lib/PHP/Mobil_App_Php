if (!function_exists('bkic_get_authenticated_user')) {
    function bkic_get_authenticated_user($request = null) {
        $header = bkic_get_authorization_header($request);

        if (!$header || stripos($header, 'Bearer ') !== 0) {
            return null;
        }

        $token = trim(substr($header, 7));
        if (!$token) {
            return null;
        }

        $users = get_users([
            'meta_key'    => 'bkic_app_token',
            'meta_value'  => $token,
            'number'      => 1,
            'count_total' => false,
            'fields'      => 'all',
        ]);

        if (empty($users) || !($users[0] instanceof WP_User)) {
            return null;
        }

        return $users[0];
    }
}

if (!function_exists('bkic_authorize_request')) {
    function bkic_authorize_request($request) {
        return (bool) bkic_get_authenticated_user($request);
    }
}

if (!function_exists('bkic_authorize_admin_request')) {
    function bkic_authorize_admin_request($request) {
        $user = bkic_get_authenticated_user($request);
        if (!$user) {
            return false;
        }
        return user_can($user, 'manage_options');
    }
}

if (!function_exists('bkic_find_user_by_identifier')) {
    function bkic_find_user_by_identifier($identifier) {
        $identifier = trim((string) $identifier);

        if (!$identifier) {
            return false;
        }

        $user = get_user_by('email', $identifier);
        if (!$user) {
            $user = get_user_by('login', $identifier);
        }

        return $user;
    }
}

/**
 * =========================
 * TIME HELPERS
 * =========================
 */
if (!function_exists('bkic_mobile_now_ts')) {
    function bkic_mobile_now_ts() {
        try {
            return (new DateTimeImmutable('now', new DateTimeZone('Europe/Copenhagen')))->getTimestamp();
        } catch (Exception $e) {
            return time();
        }
    }
}

if (!function_exists('bkic_mobile_parse_dt_to_ts')) {
    function bkic_mobile_parse_dt_to_ts($raw) {
        $raw = trim((string) $raw);
        if ($raw === '') {
            return 0;
        }

        $raw = preg_replace('/\s+/', ' ', $raw);
        $tz = new DateTimeZone('Europe/Copenhagen');

        $candidates = [
            'd.m.Y, H.i',
            'd.m.Y H.i',
            'd.m.Y, H:i',
            'd.m.Y H:i',
            'd-m-Y, H:i',
            'd-m-Y H:i',
            'Y-m-d H:i',
            'Y-m-d\TH:i',
            'Y-m-d\TH:i:s',
            'd.m.Y',
            'd-m-Y',
            'Y-m-d',
        ];

        foreach ($candidates as $fmt) {
            $dt = DateTimeImmutable::createFromFormat($fmt, $raw, $tz);
            if ($dt instanceof DateTimeImmutable) {
                $errors = DateTimeImmutable::getLastErrors();
                if (!empty($errors['warning_count']) || !empty($errors['error_count'])) {
                    continue;
                }
                return (int) $dt->getTimestamp();
            }
        }

        try {
            $dt2 = new DateTimeImmutable($raw, $tz);
            return (int) $dt2->getTimestamp();
        } catch (Exception $e) {
            return 0;
        }
    }
}

/**
 * =========================
 * MEMBERSHIP HELPERS
 * =========================
 */
if (!function_exists('bkic_mobile_is_member_active')) {
    function bkic_mobile_is_member_active($user_id = 0) {
        $user_id = $user_id ? (int) $user_id : (int) get_current_user_id();
        if (!$user_id) {
            return false;
        }

        $user = get_user_by('id', $user_id);
        if (!$user) {
            return false;
        }

        if (in_array('administrator', (array) $user->roles, true)) {
            return true;
        }

        if (!in_array('bkic_member', (array) $user->roles, true)) {
            return false;
        }

        $raw = get_user_meta($user_id, 'bkic_member_expires', true);
        $raw = is_string($raw) ? trim($raw) : $raw;

        if ($raw !== '' && $raw !== null) {
            $expires = 0;

            if (is_numeric($raw)) {
                $n = (int) $raw;
                if ($n > 1000000000) {
                    $expires = $n;
                }
            } else {
                $expires = bkic_mobile_parse_dt_to_ts((string) $raw);
            }

            if ($expires > 0 && $expires <= bkic_mobile_now_ts()) {
                return false;
            }
        }

        return true;
    }
}

if (!function_exists('bkic_mobile_can_view_vijesti')) {
    function bkic_mobile_can_view_vijesti($user_id = 0) {
        $user_id = $user_id ? (int) $user_id : (int) get_current_user_id();

        if (!$user_id) {
            return false;
        }

        $user = get_user_by('id', $user_id);
        if (!$user) {
            return false;
        }

        if (in_array('administrator', (array) $user->roles, true)) {
            return true;
        }

        return bkic_mobile_is_member_active($user_id);
    }
}

/**
 * =========================
 * VIJESTI
 * =========================
 */
if (!function_exists('bkic_mobile_get_vijesti_for_user')) {
    function bkic_mobile_get_vijesti_for_user($user_id, $limit = 20) {
        $user_id = (int) $user_id;
        $limit = (int) $limit;

        if ($limit <= 0) {
            $limit = 20;
        }

        if ($limit > 20) {
            $limit = 20;
        }

        if (!bkic_mobile_can_view_vijesti($user_id)) {
            return new WP_Error('forbidden', 'Ingen adgang til vijesti', ['status' => 403]);
        }

        $now = bkic_mobile_now_ts();

        $q = new WP_Query([
            'post_type'      => BKIC_VIJEST_POST_TYPE,
            'post_status'    => 'publish',
            'posts_per_page' => $limit,
            'no_found_rows'  => true,
            'meta_key'       => '_bkic_end_ts',
            'orderby'        => 'meta_value_num',
            'order'          => 'ASC',
            'meta_query'     => [
                [
                    'key'     => '_bkic_end_ts',
                    'value'   => $now,
                    'compare' => '>=',
                    'type'    => 'NUMERIC',
                ],
            ],
        ]);

        $out = [];

        foreach ($q->posts as $p) {
            $start_raw = (string) get_post_meta($p->ID, '_bkic_start', true);
            $end_raw   = (string) get_post_meta($p->ID, '_bkic_end', true);

            $start_ts = (int) get_post_meta($p->ID, '_bkic_start_ts', true);
            $end_ts   = (int) get_post_meta($p->ID, '_bkic_end_ts', true);

            if (!$end_ts) {
                $end_ts = bkic_mobile_parse_dt_to_ts($end_raw);
            }

            if (!$start_ts && $start_raw !== '') {
                $start_ts = bkic_mobile_parse_dt_to_ts($start_raw);
            }

            if (!$end_ts || $end_ts < $now) {
                continue;
            }

            $out[] = [
                'id'    => (int) $p->ID,
                'title' => html_entity_decode(get_the_title($p), ENT_QUOTES, 'UTF-8'),
                'text'  => wp_strip_all_tags(apply_filters('the_content', $p->post_content)),
                'start' => $start_raw,
                'end'   => $end_raw,
            ];
        }

        wp_reset_postdata();

        return $out;
    }
}

