add_action('save_post', function ($post_id, $post, $update) {
    if (wp_is_post_revision($post_id) || wp_is_post_autosave($post_id)) {
        return;
    }

    if (!$post || !($post instanceof WP_Post)) {
        bkic_push_log('save_post invalid post', ['post_id' => $post_id]);
        return;
    }

    bkic_push_log('save_post fired', [
        'post_id' => $post_id,
        'post_type' => $post->post_type,
        'status' => $post->post_status,
        'update' => $update,
    ]);

    if ($post->post_type !== BKIC_VIJEST_POST_TYPE) {
        return;
    }

    if ($post->post_status !== 'publish') {
        bkic_push_log('Vijest not publish, skipping', [
            'post_id' => $post_id,
            'status' => $post->post_status,
        ]);
        return;
    }

    if (!bkic_push_enabled()) {
        bkic_push_log('FCM not enabled, skipping vijest push', ['post_id' => $post_id]);
        return;
    }

    $already_sent = get_post_meta($post_id, '_bkic_push_sent_vijest', true);
    if ($already_sent) {
        bkic_push_log('Vijest push already sent, skipping', [
            'post_id' => $post_id,
            'already_sent' => $already_sent,
        ]);
        return;
    }

    $title = html_entity_decode(get_the_title($post), ENT_QUOTES, 'UTF-8');

    $result = bkic_push_send_to_all_devices([
        'title' => 'Nova vijest',
        'body'  => $title,
        'data'  => [
            'type'    => 'vijest',
            'post_id' => (string) $post_id,
            'title'   => $title,
        ],
    ]);

    bkic_push_log('Vijest push result', [
        'post_id' => $post_id,
        'result' => $result,
    ]);

    update_post_meta($post_id, '_bkic_push_sent_vijest', current_time('mysql'));
}, 10, 3);

add_action('updated_option', function ($option, $old_value, $value) {
    if ($option !== 'bkic_events_data') {
        return;
    }

    bkic_push_log('updated_option for bkic_events_data fired');

    if (!bkic_push_enabled()) {
        bkic_push_log('FCM not enabled, skipping event push');
        return;
    }

    $old_events = is_array($old_value) ? array_values($old_value) : [];
    $new_events = is_array($value) ? array_values($value) : [];

    $old_keys = [];
    foreach ($old_events as $event) {
        $old_keys[bkic_push_event_fingerprint($event)] = true;
    }

    $pushed = get_option('bkic_mobile_pushed_event_keys', []);
    if (!is_array($pushed)) {
        $pushed = [];
    }

    foreach ($new_events as $event) {
        $fingerprint = bkic_push_event_fingerprint($event);

        if (isset($old_keys[$fingerprint])) {
            continue;
        }

        if (!empty($pushed[$fingerprint])) {
            continue;
        }

        $title = html_entity_decode((string) ($event['title'] ?? ''), ENT_QUOTES, 'UTF-8');
        if ($title === '') {
            continue;
        }

        $date = (string) ($event['date'] ?? '');
        $time = (string) ($event['time'] ?? '');

        $result = bkic_push_send_to_all_devices([
            'title' => 'Novi događaj',
            'body'  => $title,
            'data'  => [
                'type'      => 'dogadjaj',
                'event_id'  => (string) ($event['id'] ?? ''),
                'title'     => $title,
                'date'      => $date,
                'time'      => $time,
                'location'  => (string) ($event['location'] ?? ''),
            ],
        ]);

        bkic_push_log('Event push result', [
            'event_id' => (string) ($event['id'] ?? ''),
            'title' => $title,
            'result' => $result,
        ]);

        $pushed[$fingerprint] = time();
    }

    update_option('bkic_mobile_pushed_event_keys', $pushed, false);
}, 10, 3);