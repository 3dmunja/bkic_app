if (!function_exists('bkic_get_authorization_header')) {
    function bkic_get_authorization_header($request = null) {
        $header = '';

        if ($request && method_exists($request, 'get_header')) {
            $header = (string) $request->get_header('authorization');
            if (!$header) {
                $header = (string) $request->get_header('Authorization');
            }
        }

        if (!$header && isset($_SERVER['HTTP_AUTHORIZATION'])) {
            $header = (string) $_SERVER['HTTP_AUTHORIZATION'];
        }

        if (!$header && isset($_SERVER['REDIRECT_HTTP_AUTHORIZATION'])) {
            $header = (string) $_SERVER['REDIRECT_HTTP_AUTHORIZATION'];
        }

        if (!$header && function_exists('getallheaders')) {
            $headers = getallheaders();
            if (is_array($headers)) {
                if (!empty($headers['Authorization'])) {
                    $header = (string) $headers['Authorization'];
                } elseif (!empty($headers['authorization'])) {
                    $header = (string) $headers['authorization'];
                }
            }
        }

        return trim($header);
    }
}

/**
 * =========================
 * DB TABLE
 * =========================
 */
if (!function_exists('bkic_mobile_maybe_create_tables')) {
    function bkic_mobile_maybe_create_tables() {
        global $wpdb;

        $installed_version = get_option('bkic_mobile_db_version');
        $table_name = $wpdb->prefix . 'bkicsaff_mobile_devices';
        $charset_collate = $wpdb->get_charset_collate();

        if ($installed_version === BKIC_API_DB_VERSION) {
            return;
        }

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';

        $sql = "CREATE TABLE {$table_name} (
            id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
            user_id BIGINT UNSIGNED NULL,
            platform VARCHAR(20) NOT NULL,
            device_token TEXT NOT NULL,
            app_version VARCHAR(50) NULL,
            locale VARCHAR(20) NULL,
            is_active TINYINT(1) NOT NULL DEFAULT 1,
            last_seen_at DATETIME NULL,
            created_at DATETIME NOT NULL,
            updated_at DATETIME NOT NULL,
            PRIMARY KEY (id),
            KEY user_id (user_id),
            KEY platform (platform),
            KEY is_active (is_active)
        ) {$charset_collate};";

        dbDelta($sql);
        update_option('bkic_mobile_db_version', BKIC_API_DB_VERSION);

        bkic_push_log('DB checked/updated');
    }
}
add_action('init', 'bkic_mobile_maybe_create_tables');

