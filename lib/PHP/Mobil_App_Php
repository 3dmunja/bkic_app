if (!function_exists('bkic_manual_log_path')) {
    function bkic_manual_log_path() {
        return WP_CONTENT_DIR . '/bkic-manual-log.txt';
    }
}

if (!function_exists('bkic_push_log')) {
    function bkic_push_log($message, $context = null) {
        $file = bkic_manual_log_path();
        $time = date('Y-m-d H:i:s');

        $line = $time . ' BKIC ';
        $line .= (string) $message;

        if ($context !== null) {
            $json = wp_json_encode($context, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
            $line .= ' | ' . $json;
        }

        $line .= PHP_EOL;

        @file_put_contents($file, $line, FILE_APPEND);
    }
}

if (!function_exists('bkic_clear_manual_log')) {
    function bkic_clear_manual_log() {
        $file = bkic_manual_log_path();
        @file_put_contents($file, '');
    }
}

/**
 * Vis manuel log i admin
 */
add_action('admin_notices', function () {
    if (!current_user_can('manage_options')) {
        return;
    }

    $screen = function_exists('get_current_screen') ? get_current_screen() : null;
    if ($screen && strpos((string) $screen->id, 'dashboard') === false && strpos((string) $screen->id, 'snippet') === false) {
        return;
    }

    if (isset($_GET['bkic_clear_log']) && $_GET['bkic_clear_log'] === '1') {
        bkic_clear_manual_log();
        echo '<div class="notice notice-success"><p>BKIC log ryddet.</p></div>';
    }

    $file = bkic_manual_log_path();

    $clear_url = add_query_arg('bkic_clear_log', '1');

    echo '<div class="notice notice-info">';
    echo '<p><strong>BKIC manual log</strong> ';
    echo '<a href="' . esc_url($clear_url) . '" style="margin-left:10px;">Ryd log</a></p>';
    echo '<pre style="white-space:pre-wrap;max-height:340px;overflow:auto;">';

    if (file_exists($file)) {
        $content = @file_get_contents($file);
        if ($content !== false && $content !== '') {
            $lines = explode("\n", $content);
            $lines = array_slice($lines, -150);
            echo esc_html(implode("\n", $lines));
        } else {
            echo 'bkic-manual-log.txt findes, men er tom.';
        }
    } else {
        echo 'bkic-manual-log.txt findes ikke endnu.';
    }

    echo '</pre></div>';
});

